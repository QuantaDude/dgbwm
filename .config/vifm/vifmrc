    nnoremap ,t :!kitty &<cr>
elseif $TERMINAL != ''
    nnoremap ,t :!$TERMINAL &<cr>
endif
nnoremap ,z :edit ~/.config/sway/config<cr>
nnoremap ,x :edit ~/.config/nvim/lua/<cr>
nnoremap ,c :write | edit /home/abhirup/.config/vifm/vifmrc | restart full<cr>
nnoremap ,v :!exec %c:p &
