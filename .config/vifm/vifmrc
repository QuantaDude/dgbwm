colorscheme gruvbox

nnoremap <f1> :open<cr>
nnoremap <f2> :edit<cr>
nnoremap <f3> :mkdir<space>
nnoremap <f4> :touch<space>
nnoremap <f5> :copy<cr>
nnoremap <f6> :move<cr>
nnoremap <f8> :delete<cr>

nnoremap S :sort<cr>
set syscalls
set dotfiles
set vicmd=vim
set vimhelp
set timefmt='%Y/%m/%d %H:%M'
set vifminfo=bookmarks
set dirsize
set viewcolumns=-{name}..,8{size},16{mtime}.
set wildmenu
set wildstyle=popup
" Normal dirs
fileview */ tree %c -L 0

" Hidden dirs  
fileview *./ tree %c -L 1

" .. Parent dir
fileview ../ tree %c -L 0
    fileviewer *.pdf
        \ vifmimg pdf %px %py %pw %ph %c
        \ %pc
        \ vifmimg clear

    fileviewer *.djvu
        \ vifmimg djvu %px %py %pw %ph %c
        \ %pc
        \ vifmimg clear

    fileviewer *.epub
        \ vifmimg epub %px %py %pw %ph %c
        \ %pc
        \ vifmimg clear

    fileviewer <video/*>
        \ vifmimg video %px %py %pw %ph %c
        \ %pc
        \ vifmimg clear

    fileviewer <image/*>
        \ vifmimg draw %px %py %pw %ph %c
        \ %pc
        \ vifmimg clear

    fileviewer <audio/*>
        \ vifmimg audio %px %py %pw %ph %c
        \ %pc
        \ vifmimg clear

    fileviewer <font/*>
        \ vifmimg font %px %py %pw %ph %c
        \ %pc
        \ vifmimg clear
