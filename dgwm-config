#!/bin/sh

XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"

BASHRC="$HOME/.bashrc"

CONFIG="$XDG_DATA_HOME/dgwm/.config/dgwm/dgwmrc"

DGWM_LIB="$XDG_DATA_HOME/dgwm/dgwm-utils.sh"

[ -f "$DGWM_LIB" ] && . "$DGWM_LIB"
# -------- Load existing config --------
[ -f "$CONFIG" ] && . "$CONFIG"

SHELL="${SHELL:-}"
TERMINAL="${TERMINAL:-}"
BROWSER="${BROWSER:-}"
FILE_MANAGER="${FILE_MANAGER:-}"
EDITOR="${EDITOR:-}"
ED_NEEDS_TERM="${ED_NEEDS_TERM:-}"
MONITOR="${MONITOR:-}"
WEATHER_MODE="${WEATHER_MODE:-none}"
FM_NEEDS_TERM="${FM_NEEDS_TERM:-}"
MODE="${MODE:-}"
WALLPAPER="${WALLPAPER:-}"

OLD_MODE="$MODE"
OLD_WALLPAPER="$WALLPAPER"
OLD_EDITOR="${EDITOR}"
TERMINALS="st kitty alacritty wezterm ghostty konsole"
BROWSERS="firefox chromium brave qutebrowser librewolf"
FMS="vifm ranger nnn lf thunar pcmanfm dolphin"
MONITORS="btop htop top"
EDITORS="vim nvim emacs helix micro ed kate"

# --- helpers ----

choose_wallpaper() {
    DIR="$HOME/.local/share/dgwm/wallpapers/"

    files=$(find "$DIR" -type f \( \
        -iname "*.png" -o \
        -iname "*.jpg" -o \
        -iname "*.jpeg" -o \
        -iname "*.bmp" -o \
        -iname "*.gif" -o \
        -iname "*.webp" -o \
        -iname "*.tiff" \
    \))

    if [ -z "$files" ]; then
        warn "No wallpapers found in $DIR" >&2
        echo "$WALLPAPER"
        return
    fi

    echo "" >&2
    question "Select wallpaper (current: ${WALLPAPER:-none})" >&2

    i=1
    for f in $files; do
        name=$(basename "$f")
        info "  $i) $name" >&2
        eval "wp_$i=\"$f\""
        i=$((i+1))
    done

    question "Choice [Enter to keep current]: " >&2
    read choice

    if [ -z "$choice" ]; then
        echo "$WALLPAPER"
        return
    fi

    eval "echo \$wp_$choice"
}
# -------- Menu loop --------

while :; do
    clear

printf "${ORANGE}${BOLD}"
cat << "EOF"

   ‚ĖĄ‚Ėą‚Ėą‚Ėą‚Ėą  ‚Ėą     ‚Ėą‚ĖĎ ‚Ėą‚Ėą‚Ėą‚ĖĄ ‚ĖĄ‚Ėą‚Ėą‚Ėą‚Ėď
  ‚Ėą‚Ėą‚Ėí ‚ĖÄ‚Ėą‚Ėí‚Ėď‚Ėą‚ĖĎ ‚Ėą ‚ĖĎ‚Ėą‚ĖĎ‚Ėď‚Ėą‚Ėą‚Ėí‚ĖÄ‚Ėą‚ĖÄ ‚Ėą‚Ėą‚Ėí
 ‚Ėí‚Ėą‚Ėą‚ĖĎ‚ĖĄ‚ĖĄ‚ĖĄ‚ĖĎ‚Ėí‚Ėą‚ĖĎ ‚Ėą ‚ĖĎ‚Ėą ‚Ėď‚Ėą‚Ėą    ‚Ėď‚Ėą‚Ėą‚ĖĎ
 ‚ĖĎ‚Ėď‚Ėą  ‚Ėą‚Ėą‚Ėď‚ĖĎ‚Ėą‚ĖĎ ‚Ėą ‚ĖĎ‚Ėą ‚Ėí‚Ėą‚Ėą    ‚Ėí‚Ėą‚Ėą
 ‚ĖĎ‚Ėí‚Ėď‚Ėą‚Ėą‚Ėą‚ĖÄ‚Ėí‚ĖĎ‚ĖĎ‚Ėą‚Ėą‚Ėí‚Ėą‚Ėą‚Ėď ‚Ėí‚Ėą‚Ėą‚Ėí   ‚ĖĎ‚Ėą‚Ėą‚Ėí
  ‚ĖĎ‚Ėí   ‚Ėí ‚ĖĎ ‚Ėď‚ĖĎ‚Ėí ‚Ėí  ‚ĖĎ ‚Ėí‚ĖĎ   ‚ĖĎ  ‚ĖĎ
   ‚ĖĎ   ‚ĖĎ   ‚Ėí ‚ĖĎ ‚ĖĎ  ‚ĖĎ  ‚ĖĎ      ‚ĖĎ
 ‚ĖĎ ‚ĖĎ   ‚ĖĎ   ‚ĖĎ   ‚ĖĎ  ‚ĖĎ      ‚ĖĎ
       ‚ĖĎ     ‚ĖĎ           ‚ĖĎ

    Gruvbox Window Manager
        (config-cli)
EOF
    echo "==== dgwm Config ===="
    echo ""
    echo "1) Shell           : $(basename "$SHELL")"
    echo "2) Terminal        : $TERMINAL"
    echo "3) Browser         : $BROWSER"
    echo "4) File Manager    : $FILE_MANAGER"
    echo "5) System Monitor  : $MONITOR"
    echo "6) Editor          : $EDITOR"
    echo "7) Wallpaper       : ${WALLPAPER:-none}"
    echo "8) Weather         : $WEATHER_MODE"
    echo "9) Mode            : $MODE"
    echo ""
    echo "10) Save"
    echo "11) Exit"
    echo ""
    printf "${RESET}\n"
    question "Choice: "
    read choice

    case "$choice" in
        1) 
            user_shell=$(choose_program "Shell" "$SHELL" $SHELLS)
            install_shell_if_missing "$user_shell"

            shell_path="$(command -v "$user_shell")"

            success "Selected shell: $shell_path"

            # remove old SHELL export
            sed -i '/^export SHELL=/d' "$BASHRC"

            # persist shell variable
            echo "export SHELL=$shell_path" >> "$BASHRC"

            export SHELL="$shell_path"

            # change login shell if possible
            if command -v chsh >/dev/null 2>&1; then
              question "Set $user_shell as login shell using chsh? (y/n): "
              read ans

              case "$ans" in
                y|Y)
                chsh -s "$shell_path"
                success "Login shell changed to $shell_path"
                ;;
              esac
            fi
            ;;
        2)
            TERMINAL=$(choose_program "Terminal" "$TERMINAL" $(detect_programs "$TERMINALS"))
            ;;
        3)
            BROWSER=$(choose_program "Browser" "$BROWSER" $(detect_programs "$BROWSERS")) 
            ;;
        4)
            FILE_MANAGER=$(choose_program "File Manager" "$FILE_MANAGER" $(detect_programs "$FMS"))

            fm_desktop=$(get_desktop_file "$FILE_MANAGER")

            FM_NEEDS_TERM=0

            if [ -n "$fm_desktop" ]; then
                term_flag=$(get_terminal_requirement "$fm_desktop")

                if [ "$term_flag" = "1" ] || [ "$term_flag" = "0" ]; then
                    FM_NEEDS_TERM=$term_flag
                fi

                xdg-mime default "$fm_desktop" inode/directory
                xdg-mime default "$fm_desktop" x-scheme-handler/file
                xdg-mime default "$fm_desktop" "text/vnd.typst"

            else
                printf "[?] Does '%s' require terminal? (y/n): " "$FILE_MANAGER"
                    read ans
                [ "$ans" = "y" ] && FM_NEEDS_TERM=1
            fi
            ;;
        5)
            MONITOR=$(choose_program "System Monitor" "$MONITOR" $(detect_programs "$MONITORS"))
        ;;
        6)
            EDITOR=$(choose_program "Editor" "$EDITOR" $(detect_programs "$EDITORS"))

            editor_desktop=$(get_desktop_file "$EDITOR")

            ED_NEEDS_TERM=0

            if [ -n "$editor_desktop" ]; then
                term_flag=$(get_terminal_requirement "$editor_desktop")

                if [ "$term_flag" = "1" ] || [ "$term_flag" = "0" ]; then
                    ED_NEEDS_TERM=$term_flag
                fi

                set_mime_from_desktop "$editor_desktop" "text/"
                xdg-mime default "$editor_desktop" text/plain

            else
            printf "[?] Does '%s' require terminal? (y/n): " "$EDITOR"
            read ans
            [ "$ans" = "y" ] && ED_NEEDS_TERM=1
            fi
        ;;

        7)
            WALLPAPER=$(choose_wallpaper)
            ;;
        8)
            echo ""
            info "1) Disable"
            info "2) IP-based"
            info "3) Location-based"
            printf "Choice: "
            read w

            case "$w" in
                1) WEATHER_MODE="none" ;;
                2) WEATHER_MODE="ip" ;;
                3)
                    printf "Enter location: "
                    read loc
                    WEATHER_MODE="location:$loc"
                    ;;
            esac
            ;;
        9)
            if [ "$MODE" = "static" ]; then
                MODE="dynamic"
            else
                MODE="static"
            fi
            ;;
        10)
            mkdir -p "$(dirname "$CONFIG")"

cat > "$CONFIG" <<EOF
MODE=$MODE
SHELL="${shell_path:-$SHELL}"
TERMINAL=$TERMINAL
BROWSER=$BROWSER
FILE_MANAGER=$FILE_MANAGER
FM_NEEDS_TERM=$FM_NEEDS_TERM
EDITOR=$EDITOR
ED_NEEDS_TERM=$ED_NEEDS_TERM
MONITOR=$MONITOR
WEATHER_MODE=$WEATHER_MODE
WALLPAPER=$WALLPAPER
IS_LAPTOP=$IS_LAPTOP
EOF

            success "Saved."

            if [ "$MODE" != "$OLD_MODE" ]; then
                info "Mode changed ‚Üí rebuilding dwm and dwmblocks..."

                SRC="$XDG_DATA_HOME/dgwm/"

                if [ "$WEATHER_MODE" = "none" ]; then
                    WEATHER_BLOCK=0
                else
                    WEATHER_BLOCK=1
                fi

                if find /sys/class/power_supply -maxdepth 1 -name 'BAT*' | grep -q .; then
                    IS_LAPTOP=1
                else
                    IS_LAPTOP=0
                fi

                if [ "$MODE" = "dynamic" ]; then
                    (cd "$SRC/dwm" && sudo make clean DYNAMIC=1 install && sudo make clean)
                    (cd "$SRC/dwmblocks-async" && sudo make clean \
                    DYNAMIC=1 \
                    WEATHER_BLOCK=$WEATHER_BLOCK \
                    IS_LAPTOP=$IS_LAPTOP \
                    install && sudo make clean)
                else
                    (cd "$SRC/dwm" && sudo make clean \
                    TERMINAL="$TERMINAL" \
                    BROWSER="$BROWSER" \
                    FM="$FILE_MANAGER" \
                    FM_NEEDS_TERM=$FM_NEEDS_TERM \
                    DYNAMIC=0 \
                    install && sudo make clean)

                    (cd "$SRC/dwmblocks-async" && sudo make clean \
                    TERMINAL="$TERMINAL" \
                    RES_MONITOR="$MONITOR" \
                    WEATHER_BLOCK=$WEATHER_BLOCK \
                    IS_LAPTOP=$IS_LAPTOP \
                    install && sudo make clean)
                fi

            success "Rebuild complete"
            sleep 1
            killall dwm
            sleep 1
            exec dwm &
            killall dwmblocks
            sleep 1
            exec dwmblocks &
            fi

            if [ "$EDITOR" != "$OLD_EDITOR" ]; then

                sed -i '/^export EDITOR=/d' "$BASHRC"
                sed -i '/^export VISUAL=/d' "$BASHRC"

                echo "export EDITOR=$EDITOR" >> "$BASHRC"
                echo "export VISUAL=$EDITOR" >> "$BASHRC"
            fi
            if [ "$WALLPAPER" != "$OLD_WALLPAPER" ]; then
                feh --bg-fill "$WALLPAPER"
            fi        
            ;;
        11)
            exit 0
            ;;
    esac
done
