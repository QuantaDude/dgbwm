#!/bin/sh

XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"

CONFIG="$XDG_DATA_HOME/dgbwm/.config/dgbwm/dgbwmrc"

DGBWM_LIB="$XDG_DATA_HOME/dgbwm/dgbwm-utils.sh"

[ -f "$DGBWM_LIB" ] && . "$DGBWM_LIB"
# -------- Load existing config --------
[ -f "$CONFIG" ] && . "$CONFIG"

TERMINAL="${TERMINAL:-}"
BROWSER="${BROWSER:-}"
FILE_MANAGER="${FILE_MANAGER:-}"
EDITOR="${EDITOR:-}"
ED_NEEDS_TERM="${ED_NEEDS_TERM:-}"
MONITOR="${MONITOR:-}"
WEATHER_MODE="${WEATHER_MODE:-none}"
FM_NEEDS_TERM="${FM_NEEDS_TERM:-}"
MODE="${MODE:-}"
WALLPAPER="${WALLPAPER:-}"

OLD_MODE="$MODE"
OLD_WALLPAPER="$WALLPAPER"
OLD_EDITOR="${EDITOR}"
TERMINALS="st kitty alacritty ghostty konsole"
BROWSERS="firefox chromium brave qutebrowser librewolf"
FMS="vifm ranger nnn lf thunar pcmanfm dolphin"
MONITORS="btop htop top"
EDITORS="vim nvim emacs helix micro ed kate"

# --- helpers ----

choose_wallpaper() {
    DIR="$HOME/.local/share/dgbwm/wallpapers/"

    files=$(find "$DIR" -type f \( \
        -iname "*.png" -o \
        -iname "*.jpg" -o \
        -iname "*.jpeg" -o \
        -iname "*.bmp" -o \
        -iname "*.gif" -o \
        -iname "*.webp" -o \
        -iname "*.tiff" \
    \))

    if [ -z "$files" ]; then
        echo "[!] No wallpapers found in $DIR" >&2
        echo "$WALLPAPER"
        return
    fi

    echo "" >&2
    echo "[*] Select wallpaper (current: ${WALLPAPER:-none})" >&2

    i=1
    for f in $files; do
        name=$(basename "$f")
        echo "  $i) $name" >&2
        eval "wp_$i=\"$f\""
        i=$((i+1))
    done

    printf "Choice [Enter to keep current]: " >&2
    read choice

    if [ -z "$choice" ]; then
        echo "$WALLPAPER"
        return
    fi

    eval "echo \$wp_$choice"
}
# -------- Menu loop --------

while :; do
    clear
    echo "==== dgbwm Config ===="
    echo ""
    echo "1) Terminal        : $TERMINAL"
    echo "2) Browser         : $BROWSER"
    echo "3) File Manager    : $FILE_MANAGER"
    echo "4) System Monitor  : $MONITOR"
    echo "5) Editor          : $EDITOR"
    echo "6) Wallpaper       : ${WALLPAPER:-none}"
    echo "7) Weather         : $WEATHER_MODE"
    echo "8) Mode            : $MODE"
    echo ""
    echo "9) Save"
    echo "10) Exit"
    echo ""

    printf "Choice: "
    read choice

    case "$choice" in
        1)
            TERMINAL=$(choose_program "Terminal" "$TERMINAL" $(detect_programs "$TERMINALS"))
            ;;
        2)
            BROWSER=$(choose_program "Browser" "$BROWSER" $(detect_programs "$BROWSERS")) 
            ;;
        3)
            FILE_MANAGER=$(choose_program "File Manager" "$FILE_MANAGER" $(detect_programs "$FMS"))

            fm_desktop=$(get_desktop_file "$FILE_MANAGER")

            FM_NEEDS_TERM=0

            if [ -n "$fm_desktop" ]; then
                term_flag=$(get_terminal_requirement "$fm_desktop")

                if [ "$term_flag" = "1" ] || [ "$term_flag" = "0" ]; then
                    FM_NEEDS_TERM=$term_flag
                fi

                xdg-mime default "$fm_desktop" inode/directory
                xdg-mime default "$fm_desktop" x-scheme-handler/file
                xdg-mime default "$fm_desktop" "text/vnd.typst"

            else
                printf "[?] Does '%s' require terminal? (y/n): " "$FILE_MANAGER"
                    read ans
                [ "$ans" = "y" ] && FM_NEEDS_TERM=1
            fi
            ;;
        4)
            MONITOR=$(choose_program "System Monitor" "$MONITOR" $(detect_programs "$MONITORS"))
        ;;
        5)
            EDITOR=$(choose_program "Editor" "$EDITOR" $(detect_programs "$EDITORS"))

            editor_desktop=$(get_desktop_file "$EDITOR")

            ED_NEEDS_TERM=0

            if [ -n "$editor_desktop" ]; then
                term_flag=$(get_terminal_requirement "$editor_desktop")

                if [ "$term_flag" = "1" ] || [ "$term_flag" = "0" ]; then
                    ED_NEEDS_TERM=$term_flag
                fi

                set_mime_from_desktop "$editor_desktop" "text/"
                xdg-mime default "$editor_desktop" text/plain

            else
            printf "[?] Does '%s' require terminal? (y/n): " "$EDITOR"
            read ans
            [ "$ans" = "y" ] && ED_NEEDS_TERM=1
            fi
        ;;

        6)
            WALLPAPER=$(choose_wallpaper)
            ;;
        7)
            echo ""
            echo "1) Disable"
            echo "2) IP-based"
            echo "3) Location-based"
            printf "Choice: "
            read w

            case "$w" in
                1) WEATHER_MODE="none" ;;
                2) WEATHER_MODE="ip" ;;
                3)
                    printf "Enter location: "
                    read loc
                    WEATHER_MODE="location:$loc"
                    ;;
            esac
            ;;
        8)
            if [ "$MODE" = "static" ]; then
                MODE="dynamic"
            else
                MODE="static"
            fi
            ;;
        9)
            mkdir -p "$(dirname "$CONFIG")"

cat > "$CONFIG" <<EOF
MODE=$MODE
TERMINAL=$TERMINAL
BROWSER=$BROWSER
FILE_MANAGER=$FILE_MANAGER
FM_NEEDS_TERM=$FM_NEEDS_TERM
EDITOR=$EDITOR
ED_NEEDS_TERM=$ED_NEEDS_TERM
MONITOR=$MONITOR
WEATHER_MODE=$WEATHER_MODE
WALLPAPER=$WALLPAPER
IS_LAPTOP=$IS_LAPTOP
EOF

            echo "[✓] Saved."

            if [ "$MODE" != "$OLD_MODE" ]; then
                echo "[*] Mode changed → rebuilding dwm and dwmblocks..."

                SRC="$XDG_DATA_HOME/dgbwm/"

                if [ "$WEATHER_MODE" = "none" ]; then
                    WEATHER_BLOCK=0
                else
                    WEATHER_BLOCK=1
                fi

                if find /sys/class/power_supply -maxdepth 1 -name 'BAT*' | grep -q .; then
                    IS_LAPTOP=1
                else
                    IS_LAPTOP=0
                fi

                if [ "$MODE" = "dynamic" ]; then
                    (cd "$SRC/dwm" && sudo make clean DYNAMIC=1 install && sudo make clean)
                    (cd "$SRC/dwmblocks-async" && sudo make clean \
                    DYNAMIC=1 \
                    WEATHER_BLOCK=$WEATHER_BLOCK \
                    IS_LAPTOP=$IS_LAPTOP \
                    install && sudo make clean)
                else
                    (cd "$SRC/dwm" && sudo make clean \
                    TERMINAL="$TERMINAL" \
                    BROWSER="$BROWSER" \
                    FM="$FILE_MANAGER" \
                    FM_NEEDS_TERM=$FM_NEEDS_TERM \
                    DYNAMIC=0 \
                    install && sudo make clean)

                    (cd "$SRC/dwmblocks-async" && sudo make clean \
                    TERMINAL="$TERMINAL" \
                    RES_MONITOR="$MONITOR" \
                    WEATHER_BLOCK=$WEATHER_BLOCK \
                    IS_LAPTOP=$IS_LAPTOP \
                    install && sudo make clean)
                fi

            echo "[✓] Rebuild complete"
            sleep 1
            killall dwm
            sleep 1
            exec dwm &
            killall dwmblocks
            sleep 1
            exec dwmblocks &
            fi

            if [ "$EDITOR" != "$OLD_EDITOR" ]; then
                BASHRC="$HOME/.bashrc"

                sed -i '/^export EDITOR=/d' "$BASHRC"
                sed -i '/^export VISUAL=/d' "$BASHRC"

                echo "export EDITOR=$EDITOR" >> "$BASHRC"
                echo "export VISUAL=$EDITOR" >> "$BASHRC"
            fi
            if [ "$WALLPAPER" != "$OLD_WALLPAPER" ]; then
                feh --bg-fill "$WALLPAPER"
            fi        
            ;;
        10)
            exit 0
            ;;
    esac
done
