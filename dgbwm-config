#!/bin/sh

CONFIG="$HOME/.local/share/dgbwm/.config/dgbwm/dgbwmrc"

# -------- Load existing config --------
[ -f "$CONFIG" ] && . "$CONFIG"

TERMINAL="${TERMINAL:-st}"
BROWSER="${BROWSER:-firefox}"
FILE_MANAGER="${FILE_MANAGER:-vifm}"
MONITOR="${MONITOR:-top}"
WEATHER_MODE="${WEATHER_MODE:-none}"
FM_NEEDS_TERM="${FM_NEEDS_TERM:-1}"
MODE="${MODE:-static}"
WALLPAPER="${WALLPAPER:-}"

OLD_MODE="$MODE"
OLD_WALLPAPER="$WALLPAPER"
TERMINALS="st kitty alacritty ghostty konsole"
BROWSERS="firefox chromium brave qutebrowser librewolf"
FMS="vifm ranger nnn lf thunar pcmanfm dolphin"
MONITORS="btop htop top"

# --- helpers ----

detect_programs() {
    found=""
    for prog in $1; do
        if command -v "$prog" >/dev/null 2>&1; then
            found="$found $prog"
        fi
    done
    echo "$found"
}

validate_exec() {
    if command -v "$1" >/dev/null 2>&1; then
        return 0
    else
        echo "[!] '$1' not found in PATH" >&2
        return 1
    fi
}

choose() {
    category="$1"
    default="$2"
    shift 2

    options="$@"

    if [ -z "$options" ]; then
    echo "[!] No known programs found for $category" >&2
    while :; do
        printf "Enter executable manually: " >&2
        read manual
        if validate_exec "$manual"; then
            echo "$manual"
            return
        fi
    done
fi

    # Add previous choice if not in list
    found_prev=0
    for p in $options; do
        [ "$p" = "$default" ] && found_prev=1
    done

    if [ -n "$default" ] && [ "$found_prev" -eq 0 ]; then
        options="$default $options"
    fi

    echo "" >&2
    echo "[*] Select $category:" >&2

    i=1
    default_index=1

    for prog in $options; do
        echo "  $i) $prog" >&2
        eval "opt_$i=\"$prog\""

        [ "$prog" = "$default" ] && default_index=$i

        i=$((i+1))
    done

    echo "  $i) <other>" >&2
    other_index=$i

    printf "Choice [default %d]: " "$default_index" >&2
    read choice

    # default on empty
    [ -z "$choice" ] && choice=$default_index
    case "$choice" in
        ''|*[!0-9]*)
            echo "$default"
            return
            ;;
    esac

    if [ "$choice" -lt 1 ] || [ "$choice" -gt "$other_index" ]; then
        echo "$default"
        return
    fi
    
    if [ "$choice" -eq "$other_index" ]; then
        while :; do
            printf "Enter executable name: " >&2
            read manual

            if validate_exec "$manual"; then
                echo "$manual"
                return
            fi
        done
    fi

    eval "echo \"\$opt_$choice\""
}

choose_wallpaper() {
    DIR="$HOME/.local/share/dgbwm/wallpapers/"

    files=$(find "$DIR" -type f \( \
        -iname "*.png" -o \
        -iname "*.jpg" -o \
        -iname "*.jpeg" -o \
        -iname "*.bmp" -o \
        -iname "*.gif" -o \
        -iname "*.webp" -o \
        -iname "*.tiff" \
    \))

    if [ -z "$files" ]; then
        echo "[!] No wallpapers found in $DIR" >&2
        echo "$WALLPAPER"
        return
    fi

    echo "" >&2
    echo "[*] Select wallpaper (current: ${WALLPAPER:-none})" >&2

    i=1
    for f in $files; do
        name=$(basename "$f")
        echo "  $i) $name" >&2
        eval "wp_$i=\"$f\""
        i=$((i+1))
    done

    printf "Choice [Enter to keep current]: " >&2
    read choice

    if [ -z "$choice" ]; then
        echo "$WALLPAPER"
        return
    fi

    eval "echo \$wp_$choice"
}
# -------- Menu loop --------

while :; do
    clear
    echo "==== dgbwm Config ===="
    echo ""
    echo "1) Terminal        : $TERMINAL"
    echo "2) Browser         : $BROWSER"
    echo "3) File Manager    : $FILE_MANAGER"
    echo "4) System Monitor  : $MONITOR"
    echo "5) Wallpaper       : ${WALLPAPER:-none}"
    echo "6) Weather         : $WEATHER_MODE"
    echo "7) Mode            : $MODE"
    echo ""
    echo "8) Save"
    echo "9) Exit"
    echo ""

    printf "Choice: "
    read choice

    case "$choice" in
        1)
            TERMINAL=$(choose "Terminal" "$TERMINAL" $(detect_programs "$TERMINALS"))
            ;;
        2)
            BROWSER=$(choose "Browser" "$BROWSER" $(detect_programs "$BROWSERS")) 
            ;;
        3)
            FILE_MANAGER=$(choose "File Manager" "$FILE_MANAGER" $(detect_programs "$FMS"))
            FM_NEEDS_TERM=0
            case "$FILE_MANAGER" in
                vifm|ranger|nnn|lf) FM_NEEDS_TERM=1 ;;
                *)
                    printf "[?] Does '%s' require terminal? (y/n): " "$FILE_MANAGER"
                    read ans
                    [ "$ans" = "y" ] && FM_NEEDS_TERM=1
                    ;;
            esac
            ;;
        4)
            MONITOR=$(choose "System Monitor" "$MONITOR" $(detect_programs "$MONITORS"))
        ;;
        5)
            WALLPAPER=$(choose_wallpaper)
            ;;
        6)
            echo ""
            echo "1) Disable"
            echo "2) IP-based"
            echo "3) Location-based"
            printf "Choice: "
            read w

            case "$w" in
                1) WEATHER_MODE="none" ;;
                2) WEATHER_MODE="ip" ;;
                3)
                    printf "Enter location: "
                    read loc
                    WEATHER_MODE="location:$loc"
                    ;;
            esac
            ;;
        7)
            if [ "$MODE" = "static" ]; then
                MODE="dynamic"
            else
                MODE="static"
            fi
            ;;
        8)
            mkdir -p "$(dirname "$CONFIG")"

cat > "$CONFIG" <<EOF
MODE=$MODE
TERMINAL=$TERMINAL
BROWSER=$BROWSER
FILE_MANAGER=$FILE_MANAGER
FM_NEEDS_TERM=$FM_NEEDS_TERM
MONITOR=$MONITOR
WEATHER_MODE=$WEATHER_MODE
WALLPAPER=$WALLPAPER
EOF

            echo "[✓] Saved."

            if [ "$MODE" != "$OLD_MODE" ]; then
                echo "[*] Mode changed → rebuilding dwm and dwmblocks..."

                SRC="$HOME/.local/share/dgbwm"

                if [ "$WEATHER_MODE" = "none" ]; then
                    WEATHER_BLOCK=0
                else
                    WEATHER_BLOCK=1
                fi

                if find /sys/class/power_supply -maxdepth 1 -name 'BAT*' | grep -q .; then
                    IS_LAPTOP=1
                else
                    IS_LAPTOP=0
                fi

                if [ "$MODE" = "dynamic" ]; then
                    (cd "$SRC/dwm" && sudo make clean DYNAMIC=1 install && sudo make clean)
                    (cd "$SRC/dwmblocks-async" && sudo make clean \
                    DYNAMIC=1 \
                    WEATHER_BLOCK=$WEATHER_BLOCK \
                    IS_LAPTOP=$IS_LAPTOP \
                    install && sudo make clean)
                else
                    (cd "$SRC/dwm" && sudo make clean \
                    TERMINAL="$TERMINAL" \
                    BROWSER="$BROWSER" \
                    FM="$FILE_MANAGER" \
                    FM_NEEDS_TERM=$FM_NEEDS_TERM \
                    DYNAMIC=0 \
                    install && sudo make clean)

                    (cd "$SRC/dwmblocks-async" && sudo make clean \
                    TERMINAL="$TERMINAL" \
                    RES_MONITOR="$MONITOR" \
                    WEATHER_BLOCK=$WEATHER_BLOCK \
                    IS_LAPTOP=$IS_LAPTOP \
                    install && sudo make clean)
                fi

            echo "[✓] Rebuild complete"
            sleep 1
            killall dwm
            sleep 1
            exec dwm &
            killall dwmblocks
            sleep 1
            exec dwmblocks &
            fi

            if [ "$WALLPAPER" != "$OLD_WALLPAPER" ]; then
                feh --bg-fill $WALLPAPER
            fi        
            ;;
        9)
            exit 0
            ;;
    esac
done
